# Скрипты оболочки всегда с LF — иначе на Windows-раннере CI git даёт CRLF и
# ломает shebang (./publish.sh падает с "bad interpreter: /usr/bin/env bash^M").
*.sh text eol=lf

# Нормализация переводов строк для остального (git сам решает по содержимому).
* text=auto

# PowerShell-скрипты: держим как текст (BOM — это содержимое, git его сохраняет).
# BOM обязателен: PowerShell 5.1 без BOM читает .ps1 как ANSI и ломает кириллицу.
*.ps1 text eol=lf
